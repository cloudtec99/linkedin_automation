# ── Groq (free AI) ───────────────────────────────────────────────────
# Get free key at: https://console.groq.com  (no credit card)
GROQ_API_KEY=gsk_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ── Telegram ─────────────────────────────────────────────────────────
TELEGRAM_BOT_TOKEN=7123456789:AAFxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TELEGRAM_CHAT_ID=123456789

# ── LinkedIn ─────────────────────────────────────────────────────────
LINKEDIN_ACCESS_TOKEN=AQVxxxxxxxx     # expires every 60 days — see README
LINKEDIN_PERSON_URN=abc123XYZ         # from /v2/userinfo "sub" field

# ── GitHub (webhook server triggers workflows) ────────────────────────
GH_PAT=ghp_xxxxxxxxxxxxxxxxxxxx       # Fine-grained PAT: Actions read+write
GITHUB_REPOSITORY=yourusername/linkedin-groq

# ── Railway deployment ────────────────────────────────────────────────
WEBHOOK_URL=https://your-app.railway.app/webhook
PORT=3000
